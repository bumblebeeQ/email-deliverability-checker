# EmailDiag 环境变量配置
# 复制此文件为 .env.local 并填入真实值

# ============================================
# Supabase 配置（用于邮件测试数据存储）
# ============================================
# 在 https://supabase.com 创建项目后获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# 邮件测试安全配置
# ============================================
# Cloudflare Email Worker 用于验证请求的密钥
# 生成方式: openssl rand -hex 32
EMAIL_TEST_API_SECRET=your-random-secret-key

# ============================================
# 可选配置
# ============================================
# 网站URL（用于生成分享链接）
NEXT_PUBLIC_SITE_URL=https://emaildiag.com

# ============================================
# 注意事项
# ============================================
# 1. 不要将此文件提交到Git
# 2. 生产环境在 Vercel Dashboard 配置环境变量
# 3. Supabase 配置可选，未配置时使用内存存储（仅适合演示）
